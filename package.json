    "@sxzz/test-utils": "^0.5.18",
    "@types/node": "^25.9.3",
    "@typescript/native-preview": "7.0.0-dev.20260614.1",
    "bumpp": "^11.1.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsdown": "^0.22.2",
    "tsdown-preset-sxzz": "^0.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "prettier": "@sxzz/prettier-config"
}
